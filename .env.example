# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Email Configuration
# With DEBUG=True, SMTP is used when EMAIL_HOST_USER is set; otherwise OTPs only appear in the server console.
# Use LuxeEstate.smtp_backend.EmailBackend so TLS uses Certifi's CA bundle (helps on many Windows setups).
EMAIL_BACKEND=LuxeEstate.smtp_backend.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@example.com
# If django.log shows CERTIFICATE_VERIFY_FAILED / "Basic Constraints of CA cert not marked critical",
# your network is intercepting SMTP TLS. For local development only, uncomment:
# EMAIL_SMTP_INSECURE_SKIP_VERIFY=True
# Safer alternative: PEM file with your corporate root CA (keep verification enabled):
# EMAIL_SMTP_CA_BUNDLE=C:\path\to\corp-root.pem

# Site Configuration
SITE_URL=http://localhost:8000
SITE_NAME=LuxeEstate

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Google Maps & Places API (Required for map display on property pages)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Razorpay Payment Gateway (Required for property promotion payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# OpenAI API (For AI features)
OPENAI_API_KEY=your-openai-api-key

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS S3 Configuration (Optional - for media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Social Auth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Security Settings
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Logging
LOG_LEVEL=INFO

# Channels
CHANNEL_LAYERS_HOST=localhost
CHANNEL_LAYERS_PORT=6379
